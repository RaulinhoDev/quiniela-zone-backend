# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=tu_password
DB_DATABASE=quiniela_ca_v2

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=7d

# API Football (https://www.api-football.com)
API_FOOTBALL_KEY=tu_api_key_aqui
API_FOOTBALL_URL=https://v3.football.api-sports.io

# Stripe (https://dashboard.stripe.com/apikeys)
# Usar sk_test_... y pk_test_... en desarrollo, sk_live_... en producción
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# DESARROLLO: obtener con `stripe listen --forward-to localhost:3000/api/v1/stripe/webhook`
# PRODUCCIÓN: obtener en dashboard.stripe.com → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# URL base del frontend (para redirecciones de Stripe y emails)
# DESARROLLO: http://localhost:5173
# PRODUCCIÓN: https://tudominio.com
APP_URL=http://localhost:5173

# Resend — servicio de emails (https://resend.com)
# DESARROLLO: usar onboarding@resend.dev como FROM (no requiere dominio verificado)
# PRODUCCIÓN: verificar dominio en resend.com y usar noreply@tudominio.com
RESEND_API_KEY=re_...
RESEND_FROM=onboarding@resend.dev
